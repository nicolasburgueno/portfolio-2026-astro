---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;

// Split title at colon for teal accent on the second part
const colonIndex = title.indexOf(':');
const hasSplit = colonIndex !== -1;
const firstPart = hasSplit ? title.slice(0, colonIndex + 1) : title;
const secondPart = hasSplit ? title.slice(colonIndex + 1) : '';
---

<div class:list={['mb-12', className]}>
  <h2 class="font-sans font-bold leading-none" style="font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em;">
    {hasSplit ? (
      <>
        <span style="color: var(--color-bright);">{firstPart}</span>
        <span style="color: var(--color-accent);" class="teal-glow-text">{secondPart}</span>
      </>
    ) : (
      <span style="color: var(--color-accent);" class="teal-glow-text">{title}</span>
    )}
  </h2>

  {subtitle && (
    <p class="mt-3 text-base max-w-2xl" style="color: var(--color-secondary);">{subtitle}</p>
  )}

  <!-- Accent line -->
  <div class="mt-5 flex items-center gap-3">
    <div class="h-px w-12 rounded-full" style="background: var(--color-accent); box-shadow: 0 0 8px rgba(71,180,204,0.5);"></div>
    <div class="h-px w-4 rounded-full" style="background: rgba(71,180,204,0.3);"></div>
    <div class="h-px w-2 rounded-full" style="background: rgba(71,180,204,0.15);"></div>
  </div>
</div>
