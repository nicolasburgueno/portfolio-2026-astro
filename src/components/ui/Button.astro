---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
  type = 'button',
  disabled = false,
} = Astro.props;

const variantStyles = {
  primary: 'background: var(--color-accent); color: var(--color-bg); font-weight: 600; box-shadow: 0 0 20px rgba(71,180,204,0.2);',
  secondary: 'background: rgba(255,255,255,0.05); color: var(--color-text); border: 1px solid rgba(255,255,255,0.1);',
  ghost: 'background: transparent; color: var(--color-accent); border: 1px solid rgba(71,180,204,0.25);',
};

const sizeClasses = {
  sm: 'px-3 py-1.5 text-xs rounded-lg',
  md: 'px-4 py-2 text-sm rounded-xl',
  lg: 'px-6 py-3 text-sm rounded-xl',
};

const baseClasses = `inline-flex items-center gap-2 font-sans font-medium transition-all duration-150 disabled:opacity-50 disabled:cursor-not-allowed ${sizeClasses[size]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={baseClasses}
    style={variantStyles[variant]}
    data-variant={variant}
    {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class={baseClasses}
    style={variantStyles[variant]}
    data-variant={variant}
    disabled={disabled}
  >
    <slot />
  </button>
)}

<style>
  a[data-variant="primary"]:hover,
  button[data-variant="primary"]:hover {
    background: rgba(71, 180, 204, 0.85) !important;
    box-shadow: 0 0 28px rgba(71, 180, 204, 0.35) !important;
    transform: translateY(-1px);
  }

  a[data-variant="secondary"]:hover,
  button[data-variant="secondary"]:hover {
    background: rgba(255, 255, 255, 0.08) !important;
    border-color: rgba(71, 180, 204, 0.3) !important;
    transform: translateY(-1px);
  }

  a[data-variant="ghost"]:hover,
  button[data-variant="ghost"]:hover {
    background: rgba(71, 180, 204, 0.08) !important;
    border-color: rgba(71, 180, 204, 0.5) !important;
    transform: translateY(-1px);
  }
</style>
