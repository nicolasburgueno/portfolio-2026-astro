---
import { navLinks, siteConfig } from '../../data/config';
import { getLangFromUrl, useTranslations, getLocalePath } from '../../i18n/utils';
import ThemeToggle from '../islands/ThemeToggle';
import LanguageSwitch from '../islands/LanguageSwitch';
import type { UIKeys } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  const localHref = getLocalePath(lang, href);
  if (href === '/') {
    return pathname === '/' || pathname === '/es/' || pathname === '/es';
  }
  return pathname.startsWith(localHref);
}
---

<aside class="sidebar flex flex-col py-6 px-4" style="background: var(--color-bg-darker); border-right: 1px solid rgba(71, 180, 204, 0.08);">

<!-- Avatar + Identity -->
  <div class="flex flex-col items-center text-center mb-6 px-2">
    <!-- Avatar ring with teal glow -->
    <div class="relative mb-4">
      <div
        class="w-[72px] h-[72px] rounded-full overflow-hidden"
        style="border: 2px solid rgba(71,180,204,0.5); box-shadow: 0 0 16px rgba(71,180,204,0.2), 0 0 32px rgba(71,180,204,0.08);"
      >
        <img src="/avatar.jpg" alt="Nicolas Burgueño" width="72" height="72" loading="eager" fetchpriority="high" decoding="async" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
      </div>
      <!-- Availability dot -->
      {siteConfig.available && (
        <span
          class="absolute bottom-0.5 right-0.5 w-3 h-3 rounded-full border-2 pulse-dot"
          style="background: #22c55e; border-color: var(--color-bg-darker);"
          title="Available for work"
        ></span>
      )}
    </div>

    <h2 class="text-sm font-bold font-sans leading-tight" style="color: var(--color-bright); letter-spacing: -0.01em;">{siteConfig.name}</h2>
    <p class="text-xs mt-1 leading-tight" style="color: var(--color-secondary);">{siteConfig.role}</p>

    {siteConfig.available && (
      <span
        class="inline-flex items-center gap-1.5 mt-3 px-2.5 py-1 rounded-full text-[10px] font-semibold font-sans"
        style="background: rgba(71,180,204,0.08); color: var(--color-accent); border: 1px solid rgba(71,180,204,0.25);"
      >
        <span class="w-1.5 h-1.5 rounded-full pulse-dot" style="background: var(--color-accent);"></span>
        {t('hero.available' as UIKeys)}
      </span>
    )}
  </div>

  <!-- Divider with teal tint -->
  <div class="h-px mb-5 mx-2" style="background: linear-gradient(90deg, transparent, rgba(71,180,204,0.2), transparent);"></div>

  <!-- Navigation -->
  <nav class="flex-1">
    <ul class="space-y-0.5">
      {navLinks.map((link) => {
        const active = isActive(link.href);
        const href = getLocalePath(lang, link.href);
        return (
          <li>
            <a
              href={href}
              class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 relative group"
              style={active
                ? 'background: rgba(71,180,204,0.1); color: var(--color-accent); border: 1px solid rgba(71,180,204,0.2);'
                : 'color: var(--color-secondary); border: 1px solid transparent;'
              }
              data-active={active ? 'true' : 'false'}
            >
              {/* Active left accent bar */}
              {active && (
                <span
                  class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-5 rounded-r"
                  style="background: var(--color-accent);"
                ></span>
              )}

              <!-- Icon -->
              <span class="w-4 h-4 flex-shrink-0 flex items-center justify-center">
                {link.icon === 'House' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                )}
                {link.icon === 'User' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                )}
                {link.icon === 'FolderKanban' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/><path d="M8 10v4"/><path d="M12 10v2"/><path d="M16 10v6"/></svg>
                )}
                {link.icon === 'Layers' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                )}
                {link.icon === 'BookOpen' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                )}
                {link.icon === 'Mail' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                )}
              </span>
              <span class="font-sans text-xs font-semibold tracking-wide uppercase">{t(link.labelKey as UIKeys)}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <!-- Bottom section -->
  <div class="mt-auto">
    <!-- Theme + Language toggles -->
    <div class="flex items-center justify-between px-1 mb-4">
      <ThemeToggle client:load />
      <LanguageSwitch lang={lang} client:load />
    </div>

    <!-- Divider -->
    <div class="h-px mb-4 mx-2" style="background: linear-gradient(90deg, transparent, rgba(71,180,204,0.15), transparent);"></div>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-2">
      <a
        href={siteConfig.github}
        target="_blank"
        rel="noopener noreferrer"
        class="p-2.5 rounded-lg transition-all duration-150 group"
        style="color: var(--color-secondary); background: transparent;"
        aria-label="GitHub"
        onmouseover="this.style.color='var(--color-accent)'; this.style.background='rgba(71,180,204,0.08)';"
        onmouseout="this.style.color='var(--color-secondary)'; this.style.background='transparent';"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href={siteConfig.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="p-2.5 rounded-lg transition-all duration-150"
        style="color: var(--color-secondary); background: transparent;"
        aria-label="LinkedIn"
        onmouseover="this.style.color='var(--color-accent)'; this.style.background='rgba(71,180,204,0.08)';"
        onmouseout="this.style.color='var(--color-secondary)'; this.style.background='transparent';"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>
</aside>

<style>
  /* Nav item hover state via CSS since inline onmouseover is not ideal for nav */
  a[data-active="false"]:hover {
    color: var(--color-text) !important;
    background: rgba(255, 255, 255, 0.04) !important;
  }

</style>
