---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/layout/Layout.astro';
import Badge from '../../components/ui/Badge.astro';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://nicolasburgueno.dev/blog/${post.id}`)}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://nicolasburgueno.dev/blog/${post.id}`)}`;
---

<Layout title={post.data.title} description={post.data.description}>
  <div class="px-8 md:px-12 py-16">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm font-medium mb-10 transition-colors hover:text-[var(--color-accent)]"
      style="color: var(--color-secondary);"
    >
      {t('blog.backToBlog')}
    </a>

    <!-- Article header -->
    <header class="mb-10 max-w-3xl">
      <!-- Tags row -->
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map((tag) => <Badge variant="tag">{tag}</Badge>)}
      </div>

      <!-- Title -->
      <h1
        class="font-sans font-bold mb-4"
        style="font-size: clamp(1.75rem, 4vw, 2.75rem); color: var(--color-bright); line-height: 1.2; letter-spacing: -0.03em;"
      >
        {post.data.title}
      </h1>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-3 text-sm" style="color: var(--color-secondary);">
        <time>{formattedDate}</time>

        {post.data.readingTime && (
          <>
            <span style="color: rgba(71,180,204,0.3);">·</span>
            <span>{post.data.readingTime} {t('blog.minRead')}</span>
          </>
        )}

        {post.data.originalUrl && (
          <>
            <span style="color: rgba(71,180,204,0.3);">·</span>
            <a
              href={post.data.originalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 transition-colors hover:text-[var(--color-accent)]"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
              {t('blog.originalOn')} ↗
            </a>
          </>
        )}
      </div>
    </header>

    <!-- Divider -->
    <div class="h-px max-w-3xl mb-10" style="background: rgba(71,180,204,0.15);"></div>

    <!-- Article content -->
    <article class="prose">
      <Content />
    </article>

    <!-- Divider -->
    <div class="h-px max-w-3xl mt-12 mb-10" style="background: rgba(71,180,204,0.15);"></div>

    <!-- Footer actions -->
    <div class="flex flex-wrap items-center gap-4 max-w-3xl">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold font-sans border transition-all hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)]"
        style="border-color: rgba(255,255,255,0.08); color: var(--color-secondary); background: rgba(255,255,255,0.02);"
      >
        {t('blog.backToBlog')}
      </a>

      <div class="flex items-center gap-3 ml-auto">
        <span class="text-xs" style="color: var(--color-secondary);">Share:</span>

        <a
          href={twitterShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold font-sans border transition-all hover:border-[var(--color-accent)]/30"
          style="border-color: rgba(255,255,255,0.08); color: var(--color-secondary); background: rgba(255,255,255,0.02);"
          aria-label="Share on Twitter"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Twitter
        </a>

        <a
          href={linkedinShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold font-sans border transition-all hover:border-[var(--color-accent)]/30"
          style="border-color: rgba(255,255,255,0.08); color: var(--color-secondary); background: rgba(255,255,255,0.02);"
          aria-label="Share on LinkedIn"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</Layout>
