---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="404 — Page Not Found">
  <div class="nf-page">

    <!-- Decorative background glow -->
    <div class="nf-glow" aria-hidden="true"></div>

    <!-- 404 glitch heading -->
    <div class="nf-code" aria-label="404">
      <span class="nf-code__main" data-text="404">404</span>
    </div>

    <p class="nf-subtitle">Page not found</p>

    <!-- Terminal window -->
    <div class="terminal" role="log" aria-live="polite" aria-label="Terminal output">
      <div class="terminal__header">
        <div class="terminal__dots">
          <span class="terminal__dot terminal__dot--red" aria-hidden="true"></span>
          <span class="terminal__dot terminal__dot--yellow" aria-hidden="true"></span>
          <span class="terminal__dot terminal__dot--green" aria-hidden="true"></span>
        </div>
        <span class="terminal__title" aria-hidden="true">zsh — nicolas@portfolio</span>
      </div>
      <div class="terminal__body" id="nf-terminal-body"></div>
    </div>

    <!-- CTA -->
    <div class="nf-cta" id="nf-cta">
      <a href="/" class="nf-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Back to home
      </a>
      <span class="nf-hint">or pick a route above ↑</span>
    </div>

  </div>
</Layout>

<style>
.nf-page {
  min-height: calc(100vh - 2rem);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rem 1.5rem;
  position: relative;
  text-align: center;
  gap: 1.25rem;
}

.nf-glow {
  position: absolute;
  top: -5%;
  left: 50%;
  transform: translateX(-50%);
  width: 70%;
  height: 420px;
  background: radial-gradient(ellipse at 50% 0%, rgba(71, 180, 204, 0.09) 0%, transparent 70%);
  pointer-events: none;
}

/* ─── 404 Glitch ─────────────────────────────────────── */
.nf-code {
  position: relative;
  line-height: 1;
}

.nf-code__main {
  display: block;
  font-family: var(--font-sans);
  font-size: clamp(6rem, 20vw, 13rem);
  font-weight: 700;
  letter-spacing: -0.06em;
  color: var(--color-bright);
  text-shadow:
    0 0 60px rgba(71, 180, 204, 0.5),
    0 0 120px rgba(71, 180, 204, 0.15);
  animation: glitch-main 7s infinite;
  position: relative;
}

.nf-code__main::before,
.nf-code__main::after {
  content: attr(data-text);
  position: absolute;
  inset: 0;
  font-family: inherit;
  font-size: inherit;
  font-weight: inherit;
  letter-spacing: inherit;
  opacity: 0;
}

.nf-code__main::before {
  color: #ff5e5b;
  clip-path: polygon(0 0, 100% 0, 100% 38%, 0 38%);
  animation: glitch-before 7s infinite;
}

.nf-code__main::after {
  color: #47d4f0;
  clip-path: polygon(0 62%, 100% 62%, 100% 100%, 0 100%);
  animation: glitch-after 7s infinite;
}

@keyframes glitch-main {
  0%, 80%, 100% { transform: none; }
  82% { transform: translateX(-3px) skewX(-0.5deg); }
  84% { transform: translateX(3px) skewX(0.5deg); }
  86% { transform: translateX(-1px); }
  88% { transform: none; }
}

@keyframes glitch-before {
  0%, 80%, 100% { opacity: 0; transform: none; }
  82% { opacity: 0.8; transform: translateX(3px); }
  84% { opacity: 0.8; transform: translateX(-3px); }
  86% { opacity: 0; }
}

@keyframes glitch-after {
  0%, 80%, 100% { opacity: 0; transform: none; }
  82% { opacity: 0.6; transform: translateX(-3px); }
  84% { opacity: 0.6; transform: translateX(3px); }
  86% { opacity: 0; }
}

/* ─── Subtitle ────────────────────────────────────────── */
.nf-subtitle {
  font-family: var(--font-body);
  font-size: clamp(0.85rem, 2vw, 1rem);
  color: var(--color-secondary);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 500;
}

/* ─── Terminal window ─────────────────────────────────── */
.terminal {
  width: 100%;
  max-width: 560px;
  border-radius: 10px;
  border: 1px solid rgba(71, 180, 204, 0.15);
  background: var(--color-bg-darker);
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(0, 0, 0, 0.35),
    0 24px 64px rgba(0, 0, 0, 0.45),
    0 0 60px rgba(71, 180, 204, 0.04);
  text-align: left;
}

.terminal__header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.65rem 1rem;
  background: rgba(255, 255, 255, 0.025);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.terminal__dots {
  display: flex;
  gap: 6px;
}

.terminal__dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}
.terminal__dot--red    { background: #ff5f57; }
.terminal__dot--yellow { background: #ffbd2e; }
.terminal__dot--green  { background: #28c840; }

.terminal__title {
  flex: 1;
  text-align: center;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: rgba(200, 211, 224, 0.35);
  padding-right: 66px; /* visual center offset for dots */
}

.terminal__body {
  padding: 1rem 1.25rem 1.25rem;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  line-height: 1.65;
  min-height: 200px;
}

/* ─── Terminal line types ─────────────────────────────── */
.t-line        { display: block; white-space: pre; }
.t-prompt      { color: #28c840; }
.t-dim         { color: rgba(200, 211, 224, 0.45); }
.t-bright      { color: var(--color-bright); }
.t-err         { color: #ff5e5b; font-weight: 600; }
.t-key         { color: #e5c07b; }
.t-str         { color: #98c379; }
.t-comment     { color: rgba(136, 146, 164, 0.6); }
.t-accent      { color: var(--color-accent); }
.t-muted       { color: rgba(200, 211, 224, 0.3); }

/* Clickable route lines */
.t-route {
  display: block;
  white-space: pre;
  text-decoration: none;
  transition: opacity 0.15s;
}
.t-route:hover { opacity: 0.75; }
.t-route:hover .t-accent { text-decoration: underline; text-underline-offset: 2px; }

/* Blinking cursor */
.t-cursor {
  display: inline-block;
  width: 7px;
  height: 13px;
  background: var(--color-accent);
  vertical-align: text-bottom;
  margin-left: 1px;
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

/* ─── CTA ─────────────────────────────────────────────── */
.nf-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  opacity: 0;
  transition: opacity 0.7s ease;
}

.nf-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.55rem 1.35rem;
  border-radius: 6px;
  background: var(--color-accent);
  color: var(--color-bg);
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  box-shadow: 0 0 24px rgba(71, 180, 204, 0.25);
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.nf-btn:hover {
  background: rgba(71, 180, 204, 0.85);
  transform: translateY(-2px);
  box-shadow: 0 0 36px rgba(71, 180, 204, 0.4);
}

.nf-hint {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: rgba(136, 146, 164, 0.4);
}

/* ─── Light mode adjustments ──────────────────────────── */
[data-theme="light"] .terminal {
  border-color: rgba(71, 180, 204, 0.2);
  box-shadow:
    0 0 0 1px rgba(0, 0, 0, 0.06),
    0 24px 64px rgba(0, 0, 0, 0.1);
}

[data-theme="light"] .t-comment { color: rgba(60, 70, 90, 0.5); }
[data-theme="light"] .t-dim     { color: rgba(26, 26, 46, 0.45); }
[data-theme="light"] .t-muted   { color: rgba(26, 26, 46, 0.3); }
</style>

<script>
document.addEventListener('astro:page-load', () => {
  const body = document.getElementById('nf-terminal-body');
  const cta  = document.getElementById('nf-cta');
  if (!body) return;

  const LINE_GAP = 110; // ms between lines

  const lines: Array<
    | { kind: 'parts'; parts: { text: string; cls: string }[] }
    | { kind: 'empty' }
    | { kind: 'route'; href: string; label: string; desc: string }
  > = [
    {
      kind: 'parts',
      parts: [
        { text: 'nicolas@portfolio', cls: 't-prompt' },
        { text: ' ~ % ',             cls: 't-dim'    },
        { text: 'http GET /this-page', cls: 't-bright' },
      ],
    },
    { kind: 'empty' },
    {
      kind: 'parts',
      parts: [
        { text: '  HTTP/1.1 ', cls: 't-dim' },
        { text: '404 Not Found', cls: 't-err' },
      ],
    },
    { kind: 'empty' },
    { kind: 'parts', parts: [{ text: '  {', cls: 't-dim' }] },
    {
      kind: 'parts',
      parts: [
        { text: '    "error"',              cls: 't-key'  },
        { text: ':   ',                     cls: 't-dim'  },
        { text: '"ERR_ROUTE_NOT_FOUND"',    cls: 't-str'  },
        { text: ',',                        cls: 't-dim'  },
      ],
    },
    {
      kind: 'parts',
      parts: [
        { text: '    "status"',             cls: 't-key'  },
        { text: ':  ',                      cls: 't-dim'  },
        { text: '"404"',                    cls: 't-str'  },
        { text: ',',                        cls: 't-dim'  },
      ],
    },
    {
      kind: 'parts',
      parts: [
        { text: '    "hint"',               cls: 't-key'  },
        { text: ':    ',                    cls: 't-dim'  },
        { text: '"Try one of the routes below"', cls: 't-str' },
      ],
    },
    { kind: 'parts', parts: [{ text: '  }', cls: 't-dim' }] },
    { kind: 'empty' },
    { kind: 'parts', parts: [{ text: '  # Available routes:', cls: 't-comment' }] },
    { kind: 'route', href: '/',          label: '/           ', desc: '→  home'         },
    { kind: 'route', href: '/about',     label: '/about       ', desc: '→  about me'     },
    { kind: 'route', href: '/projects',  label: '/projects    ', desc: '→  my work'      },
    { kind: 'route', href: '/contact',   label: '/contact     ', desc: '→  get in touch' },
  ];

  // Create cursor element and append it first
  const cursor = document.createElement('span');
  cursor.className = 't-cursor';
  body.appendChild(cursor);

  let index = 0;

  function buildParts(parts: { text: string; cls: string }[]) {
    const span = document.createElement('span');
    span.className = 't-line';
    parts.forEach(p => {
      const s = document.createElement('span');
      s.className = p.cls;
      s.textContent = p.text;
      span.appendChild(s);
    });
    return span;
  }

  function renderNext() {
    if (index >= lines.length) {
      // Remove cursor, show CTA
      cursor.remove();
      if (cta) {
        setTimeout(() => { cta.style.opacity = '1'; }, 200);
      }
      return;
    }

    const line = lines[index++];

    if (line.kind === 'empty') {
      const el = document.createElement('span');
      el.className = 't-line';
      el.innerHTML = '&nbsp;';
      body.insertBefore(el, cursor);
    } else if (line.kind === 'parts') {
      body.insertBefore(buildParts(line.parts), cursor);
    } else if (line.kind === 'route') {
      const a = document.createElement('a');
      a.className = 't-route';
      a.href = line.href;

      const indent = document.createElement('span');
      indent.className = 't-muted';
      indent.textContent = '  ';

      const pathSpan = document.createElement('span');
      pathSpan.className = 't-accent';
      pathSpan.textContent = line.label;

      const descSpan = document.createElement('span');
      descSpan.className = 't-dim';
      descSpan.textContent = line.desc;

      a.appendChild(indent);
      a.appendChild(pathSpan);
      a.appendChild(descSpan);
      body.insertBefore(a, cursor);
    }

    setTimeout(renderNext, LINE_GAP);
  }

  // Short initial pause so the page animates in first
  setTimeout(renderNext, 500);
});
</script>
