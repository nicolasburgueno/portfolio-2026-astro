---
import Layout from '../components/layout/Layout.astro';
import ContactForm from '../components/islands/ContactForm.tsx';
import { siteConfig } from '../data/config';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Pass translations to the React island as a plain object (no Astro runtime in islands)
const formTranslations = {
  name: t('contact.name'),
  email: t('contact.email'),
  subject: t('contact.subject'),
  message: t('contact.message'),
  send: t('contact.send'),
  sending: t('contact.sending'),
  success: t('contact.success'),
  error: t('contact.error'),
  errorName: t('contact.error.name'),
  errorEmail: t('contact.error.email'),
  errorSubject: t('contact.error.subject'),
  errorMessage: t('contact.error.message'),
};
---

<Layout title={t('nav.contact')}>
  <div class="px-6 md:px-10 py-10 md:py-16 w-full">

    <!-- Two-column grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- ═══════════════════════════════════════ LEFT COLUMN -->
      <div class="flex flex-col gap-8" id="contact-info">

        <!-- Heading -->
        <div data-animate="contact-heading">
          <h1
            class="text-4xl md:text-5xl font-bold leading-tight mb-4"
            style="font-family: var(--font-sans); color: var(--color-bright);"
          >
            {t('contact.heading')}{' '}
            <span style="color: var(--color-accent);" class="teal-glow-text">
              {t('contact.heading.accent')}
            </span>
          </h1>
          <p class="text-base leading-relaxed" style="color: var(--color-secondary);">
            {t('contact.intro')}
          </p>
        </div>

        <!-- Contact info cards -->
        <div class="flex flex-col gap-3" data-animate="contact-cards">

          <!-- Email card with copy -->
          <div
            class="contact-card group flex items-center gap-4 px-5 py-4 rounded-xl"
            style="background: var(--color-bg-darker); border: 1px solid rgba(71,180,204,0.1);"
          >
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background: rgba(71,180,204,0.1);"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs uppercase tracking-widest mb-0.5" style="color: var(--color-secondary);">Email</p>
              <a
                href={`mailto:${siteConfig.email}`}
                class="text-sm font-medium animated-underline truncate block"
                style="color: var(--color-text);"
              >
                {siteConfig.email}
              </a>
            </div>
            <button
              id="copy-email-btn"
              data-email={siteConfig.email}
              title={t('contact.copy')}
              class="flex-shrink-0 flex items-center gap-1.5 px-2 py-2 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity"
              style="color: var(--color-secondary);"
              aria-label={t('contact.copy')}
            >
              <svg id="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
              <svg id="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span id="copy-label" class="text-xs font-sans font-semibold" style="display:none; color: var(--color-accent);">{t('contact.copied')}</span>
            </button>
          </div>

          <!-- GitHub card -->
          <a
            href={siteConfig.github}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-card flex items-center gap-4 px-5 py-4 rounded-xl transition-all duration-200"
            style="background: var(--color-bg-darker); border: 1px solid rgba(71,180,204,0.1);"
          >
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background: rgba(71,180,204,0.1);"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent)">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs uppercase tracking-widest mb-0.5" style="color: var(--color-secondary);">GitHub</p>
              <span class="text-sm font-medium" style="color: var(--color-text);">github.com/nicolasburgueno</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 7h10v10M7 17 17 7"/>
            </svg>
          </a>

          <!-- LinkedIn card -->
          <a
            href={siteConfig.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-card flex items-center gap-4 px-5 py-4 rounded-xl transition-all duration-200"
            style="background: var(--color-bg-darker); border: 1px solid rgba(71,180,204,0.1);"
          >
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background: rgba(71,180,204,0.1);"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent)">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs uppercase tracking-widest mb-0.5" style="color: var(--color-secondary);">LinkedIn</p>
              <span class="text-sm font-medium" style="color: var(--color-text);">linkedin.com/in/nico-burgueno</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 7h10v10M7 17 17 7"/>
            </svg>
          </a>
        </div>

        <!-- Available badge -->
        <div
          class="inline-flex items-center gap-3 px-4 py-3 rounded-xl self-start"
          style="background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2);"
          data-animate="contact-badge"
        >
          <span
            class="w-2.5 h-2.5 rounded-full flex-shrink-0 pulse-dot"
            style="background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.6);"
          ></span>
          <span class="text-sm font-medium" style="color: #22c55e;">
            {t('contact.available')}
          </span>
        </div>

        <!-- Decorative geometric element -->
        <div
          class="relative h-32 overflow-hidden rounded-xl opacity-40"
          aria-hidden="true"
          data-animate="contact-deco"
        >
          <svg
            viewBox="0 0 300 120"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-full"
          >
            <!-- Grid lines -->
            {Array.from({ length: 7 }).map((_, i) => (
              <line
                x1={i * 50}
                y1="0"
                x2={i * 50}
                y2="120"
                stroke="rgba(71,180,204,0.2)"
                stroke-width="0.5"
              />
            ))}
            {Array.from({ length: 4 }).map((_, i) => (
              <line
                x1="0"
                y1={i * 40}
                x2="300"
                y2={i * 40}
                stroke="rgba(71,180,204,0.2)"
                stroke-width="0.5"
              />
            ))}
            <!-- Accent geometric shapes -->
            <circle cx="150" cy="60" r="40" stroke="rgba(71,180,204,0.25)" stroke-width="1" fill="none" />
            <circle cx="150" cy="60" r="20" stroke="rgba(71,180,204,0.4)" stroke-width="1" fill="none" />
            <circle cx="150" cy="60" r="3" fill="rgba(71,180,204,0.8)" />
            <!-- Cross lines -->
            <line x1="110" y1="60" x2="190" y2="60" stroke="rgba(71,180,204,0.3)" stroke-width="0.5" />
            <line x1="150" y1="20" x2="150" y2="100" stroke="rgba(71,180,204,0.3)" stroke-width="0.5" />
            <!-- Corner accents -->
            <path d="M0 0 L20 0 L20 2 L2 2 L2 20 L0 20 Z" fill="rgba(71,180,204,0.5)" />
            <path d="M300 120 L280 120 L280 118 L298 118 L298 100 L300 100 Z" fill="rgba(71,180,204,0.5)" />
          </svg>
        </div>

      </div>

      <!-- ═══════════════════════════════════════ RIGHT COLUMN -->
      <div
        class="rounded-2xl p-5 md:p-8"
        style="background: var(--color-bg-darker); border: 1px solid rgba(71,180,204,0.08);"
        id="contact-form-panel"
      >
        <h2
          class="text-lg font-semibold mb-6"
          style="font-family: var(--font-sans); color: var(--color-bright);"
        >
          Send me a message
        </h2>

        <ContactForm client:load lang={lang} t={formTranslations} />
      </div>

    </div>
  </div>
</Layout>

<!-- Contact cards hover style + copy-to-clipboard behavior -->
<style>
  .contact-card {
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .contact-card:hover {
    border-color: rgba(71, 180, 204, 0.3) !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
    transform: translateY(-2px);
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initContact() {
    // --- GSAP entrance animations ---
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.fromTo(
      '#contact-info > *',
      { opacity: 0, x: -30 },
      { opacity: 1, x: 0, duration: 0.55, stagger: 0.1 }
    ).fromTo(
      '#contact-form-panel',
      { opacity: 0, x: 30 },
      { opacity: 1, x: 0, duration: 0.6 },
      '-=0.4'
    );

    // --- Copy to clipboard ---
    const btn = document.getElementById('copy-email-btn') as HTMLButtonElement | null;
    const copyIcon = document.getElementById('copy-icon') as SVGElement | null;
    const checkIcon = document.getElementById('check-icon') as SVGElement | null;
    const copyLabel = document.getElementById('copy-label') as HTMLSpanElement | null;

    btn?.addEventListener('click', async () => {
      const email = btn.getAttribute('data-email') ?? '';
      try {
        await navigator.clipboard.writeText(email);
      } catch {
        const el = document.createElement('textarea');
        el.value = email;
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
      }

      // Show feedback
      if (copyIcon) copyIcon.style.display = 'none';
      if (checkIcon) checkIcon.style.display = 'block';
      if (copyLabel) copyLabel.style.display = 'inline';
      if (btn) btn.style.opacity = '1';

      setTimeout(() => {
        if (copyIcon) copyIcon.style.display = 'block';
        if (checkIcon) checkIcon.style.display = 'none';
        if (copyLabel) copyLabel.style.display = 'none';
        if (btn) btn.style.opacity = '';
      }, 2000);
    });
  }

  document.addEventListener('astro:page-load', initContact);
</script>
