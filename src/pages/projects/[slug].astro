---
import Layout from '../../components/layout/Layout.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import ImageGallery from '../../components/islands/ImageGallery';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

// Stack grouping — rough heuristic
const frontendKeywords = ['React', 'Redux', 'Styled Components', 'React Native', 'Next.js', 'Tailwind CSS', 'Ionic'];
const backendKeywords = ['Node.js', 'Express', 'NestJS', 'JWT', 'Bcrypt', 'Mercado Pago', 'Apollo Client'];
const dbKeywords = ['PostgreSQL', 'Sequelize', 'Supabase', 'Prisma'];
const langKeywords = ['TypeScript', 'JavaScript', 'GraphQL'];

const groupStack = (stack: readonly string[]) => {
  const groups: Record<string, string[]> = {
    Frontend: [],
    Backend: [],
    Database: [],
    Language: [],
    Other: [],
  };
  stack.forEach((tech) => {
    if (frontendKeywords.includes(tech)) groups.Frontend.push(tech);
    else if (backendKeywords.includes(tech)) groups.Backend.push(tech);
    else if (dbKeywords.includes(tech)) groups.Database.push(tech);
    else if (langKeywords.includes(tech)) groups.Language.push(tech);
    else groups.Other.push(tech);
  });
  return groups;
};

const stackGroups = groupStack(project.stack);
---

<Layout title={project.title} description={project.shortDesc}>
  <div class="px-6 md:px-10 py-12 w-full">

    <!-- Back link -->
    <div class="mb-8">
      <Button href="/projects" variant="ghost" size="sm">
        ← Back to Projects
      </Button>
    </div>

    <!-- Header -->
    <div class="mb-8" data-animate="fade-up">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <Badge variant="category">{project.category}</Badge>
        {project.featured && (
          <span
            class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-bold font-sans uppercase tracking-wider"
            style="background: rgba(71,180,204,0.15); color: var(--color-accent); border: 1px solid rgba(71,180,204,0.35);"
          >
            <span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-accent);"></span>
            Featured
          </span>
        )}
      </div>

      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <h1
            class="font-sans font-bold mb-3"
            style="font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; color: var(--color-bright); line-height: 1.1;"
          >
            {project.title}
          </h1>
          <p class="text-base leading-relaxed max-w-2xl" style="color: var(--color-secondary);">
            {project.shortDesc}
          </p>
        </div>

        <!-- Links -->
        <div class="flex flex-wrap gap-2 shrink-0">
          {project.github && (
            <Button href={project.github} variant="secondary" size="sm" external>
              GitHub ↗
            </Button>
          )}
          {'githubBackend' in project && project.githubBackend && (
            <Button href={project.githubBackend as string} variant="secondary" size="sm" external>
              Backend ↗
            </Button>
          )}
          {project.live && (
            <Button href={project.live} variant="primary" size="sm" external>
              Live Demo ↗
            </Button>
          )}
        </div>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-5">
        {project.tags.map((tag) => <Badge variant="tag">{tag}</Badge>)}
      </div>
    </div>

    <!-- ── Two-column layout on large screens ── -->
    <div class="grid grid-cols-1 xl:grid-cols-[1fr_380px] gap-10 items-start">

      <!-- Left: Gallery -->
      <div data-animate="fade-up">
        <ImageGallery client:load images={project.images} title={project.title} />

        <!-- About section (below gallery) -->
        <div class="mt-10" data-animate="fade-up">
          <h2
            class="font-sans font-bold mb-4"
            style="font-size: 1.25rem; color: var(--color-bright); letter-spacing: -0.02em;"
          >
            About the Project
          </h2>
          <p class="text-sm leading-relaxed" style="color: var(--color-secondary);">
            {project.intro}
          </p>
        </div>

        <!-- Features (below about on large screens) -->
        <div class="mt-10" data-animate="fade-up">
          <h2
            class="font-sans font-bold mb-5"
            style="font-size: 1.25rem; color: var(--color-bright); letter-spacing: -0.02em;"
          >
            What you can do
          </h2>
          <div class={`grid gap-5 ${project.appFeatures ? 'sm:grid-cols-2' : 'grid-cols-1'}`}>
            <div
              class="rounded-2xl p-5"
              style="background: var(--color-bg-darker); border: 1px solid rgba(255,255,255,0.06);"
            >
              <div class="flex items-center gap-2 mb-3">
                <span style="color: var(--color-accent);">◈</span>
                <h3 class="font-sans font-semibold text-xs uppercase tracking-wider" style="color: var(--color-accent);">
                  {project.appFeatures ? 'Web App' : 'Features'}
                </h3>
              </div>
              <ul class="space-y-2">
                {project.webFeatures.map((feat) => (
                  <li class="flex items-start gap-2 text-sm" style="color: var(--color-secondary);">
                    <span class="shrink-0 w-1 h-1 rounded-full mt-[7px]" style="background: var(--color-accent);"></span>
                    {feat}
                  </li>
                ))}
              </ul>
            </div>

            {project.appFeatures && (
              <div
                class="rounded-2xl p-5"
                style="background: var(--color-bg-darker); border: 1px solid rgba(255,255,255,0.06);"
              >
                <div class="flex items-center gap-2 mb-3">
                  <span style="color: var(--color-accent);">◈</span>
                  <h3 class="font-sans font-semibold text-xs uppercase tracking-wider" style="color: var(--color-accent);">
                    Mobile App
                  </h3>
                </div>
                <ul class="space-y-2">
                  {project.appFeatures.map((feat) => (
                    <li class="flex items-start gap-2 text-sm" style="color: var(--color-secondary);">
                      <span class="shrink-0 w-1 h-1 rounded-full mt-[7px]" style="background: var(--color-accent);"></span>
                      {feat}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Right sidebar: Tech stack (sticky on large screens) -->
      <aside class="xl:sticky xl:top-8" data-animate="fade-up">
        <div
          class="rounded-2xl p-6"
          style="background: var(--color-bg-darker); border: 1px solid rgba(255,255,255,0.06);"
        >
          <h2
            class="font-sans font-bold mb-5 text-sm uppercase tracking-wider"
            style="color: var(--color-accent);"
          >
            Technologies Used
          </h2>

          <div class="space-y-4">
            {Object.entries(stackGroups).map(([group, techs]) =>
              techs.length > 0 ? (
                <div>
                  <span
                    class="block text-[10px] font-sans font-semibold uppercase tracking-wider mb-2"
                    style="color: rgba(71,180,204,0.4);"
                  >
                    {group}
                  </span>
                  <div class="flex flex-wrap gap-1.5">
                    {techs.map((tech) => (
                      <span
                        class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium font-sans"
                        style="background: rgba(255,255,255,0.05); color: var(--color-text); border: 1px solid rgba(255,255,255,0.1);"
                      >
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              ) : null
            )}
          </div>
        </div>
      </aside>

    </div>

  </div>
</Layout>
